# --- Claude API ---------------------------------------------------------
# console.anthropic.com → API keys
ANTHROPIC_API_KEY=sk-ant-...

# --- Google Sheets (the datastore) --------------------------------------
# 1. console.cloud.google.com → create a project (e.g. "ai-budgetter")
# 2. APIs & Services → Library → enable "Google Sheets API"
# 3. IAM & Admin → Service Accounts → Create (no roles needed)
#    → Keys → Add key → JSON → download the file
# 4. base64-encode the JSON key file:  base64 -i key.json | pbcopy
GOOGLE_SERVICE_ACCOUNT_KEY_BASE64=

# 5. Open your "AI Budgetter" spreadsheet → Share → add the service
#    account's client_email (from the JSON key) as Editor.
# 6. Copy the spreadsheet ID from the URL (between /d/ and /edit):
GOOGLE_SPREADSHEET_ID=

# --- Auth ----------------------------------------------------------------
# Generate with:  openssl rand -base64 32
AUTH_SECRET=

# Optional — enables "Sign in with Google". Same GCP project:
# APIs & Services → OAuth consent screen (External, add yourself as test user)
# → Credentials → Create OAuth client ID → Web application
# → Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
